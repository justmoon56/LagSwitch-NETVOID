-- Transparency System
local function ApplyMode()
    if Save.Mode == 1 then -- NORMAL
        Panel.ImageTransparency = 0.3
        Panel.BackgroundTransparency = 1

        Title.TextTransparency = 0
        Status.TextTransparency = 0

        Stroke.Transparency = 0
        Glow.Transparency = 0.7
        TrailStroke.Transparency = 1

        Lock.BackgroundTransparency = 0
        Lock.TextTransparency = 0
        Gear.BackgroundTransparency = 0
        Gear.TextTransparency = 0

    elseif Save.Mode == 2 then -- SMART
        Panel.ImageTransparency = 1
        Panel.BackgroundTransparency = 1

        Title.TextTransparency = 1
        Status.TextTransparency = 1

        Stroke.Transparency = 1
        Glow.Transparency = 1
        TrailStroke.Transparency = 1

        Lock.BackgroundTransparency = 0
        Lock.TextTransparency = 0
        Gear.BackgroundTransparency = 0
        Gear.TextTransparency = 0

    elseif Save.Mode == 3 then -- FULL
        Panel.ImageTransparency = 1
        Panel.BackgroundTransparency = 1

        Title.TextTransparency = 1
        Status.TextTransparency = 1

        Stroke.Transparency = 1
        Glow.Transparency = 1

        Lock.BackgroundTransparency = 1
        Lock.TextTransparency = 1
        Gear.BackgroundTransparency = 1
        Gear.TextTransparency = 1
    end
end

