-- RGB Loop
task.spawn(function()
    while true do
        local t = tick()
        local move = t * 2 * Save.RGBSpeed

        Gradient.Rotation += 1 * Save.RGBSpeed
        GradientGlow.Rotation += 1 * Save.RGBSpeed
        TrailGradient.Rotation += 4 * Save.RGBSpeed

        local offset = Vector2.new(math.cos(move), math.sin(move))

        Gradient.Offset = offset
        GradientGlow.Offset = offset
        TrailGradient.Offset = Vector2.new(move % 1, 0)

        task.wait(0.02)
    end
end)


